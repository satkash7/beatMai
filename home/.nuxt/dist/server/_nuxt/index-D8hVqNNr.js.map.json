{"file":"index-D8hVqNNr.js","mappings":";;;;;;;;;;;;;;;;;;AAyNA,MAAK,YAAU;AAAA,EACb,MAAM;AAAA,EACN,QAAQ;AAAA,EACR,QAAQ,CAAC,QAAQ;AAAA,EACjB,OAAO;AACL,WAAO;AAAA,MACL,WAAW;AAAA,MACX,eAAe;AAAA,MACf,YAAY;AAAA,MACZ,eAAe;AAAA,MACf,cAAc;AAAA,MACd,eAAe;AAAA,MACf,kBAAkB;AAAA,MAClB,WAAW;AAAA,MACX,WAAW;AAAA,MACX,UAAU;AAAA,MACV,aAAa;AAAA,MACb,gBAAgB;AAAA,MAChB,cAAc;AAAA,MACd,SAAS;AAAA,IAAA;AAAA,EAEb;AAAA,EACA,UAAU;AAAA,IACR,oBAAoB;AAClB,YAAM,iBAAiB,KAAK,aAAa,YAAA,EAAc,UAAU,KAAK,EAAE,QAAQ,oBAAoB,EAAE;AACtG,YAAM,WAAW,eAAe,QAAQ,OAAO,EAAE;AACjD,aAAO;AAAA,IACT;AAAA,EAAA;AAAA,EAEF,SAAS;AAAA,IACP,QAAQ;AACN,cAAQ,IAAI,oBAAoB,KAAK,YAAY,KAAK,aAAa;AAAA,IACrE;AAAA,IACA,WAAW;AACT,cAAQ,IAAI,qBAAqB,KAAK,cAAc,KAAK,eAAe,KAAK,gBAAgB;AAAA,IAC/F;AAAA,IACA,WAAW,UAAU;AACnB,WAAK,YAAY,aAAa;AAAA,IAChC;AAAA,IACA,uBAAuB;AACrB,WAAK,YAAY;AACjB,UAAI,KAAK,iBAAiB,MAAM,KAAK,kBAAkB,MAAM,KAAK,qBAAqB,MAAM,KAAK,iBAAiB,SAAS,GAAG;AAC7H,eAAO;AAAA,MACT;AACA,aAAO;AAAA,IACT;AAAA,IACA,MAAM,YAAY;AAChB,UAAI;AACF,aAAK,UAAU;AACf,cAAM,WAAW,MAAM,KAAK,OAAO,KAAK,eAAe;AAAA,UACrD,OAAO,KAAK;AAAA,UACZ,UAAU,KAAK;AAAA,QAAA,CAChB;AAED,gBAAQ,IAAI,SAAS,IAAI;AACzB,cAAM,WAAW,SAAS,KAAK;AAC/B,cAAM,QAAQ,SAAS,KAAK;AAE5B,qBAAa,QAAQ,SAAS,SAAS,KAAK,KAAK,KAAK;AACtD,qBAAa,QAAQ,YAAY,SAAS,KAAK,KAAK,QAAQ;AAC5D,qBAAa,QAAQ,SAAS,KAAK;AACnC,qBAAa,QAAQ,cAAc,SAAS,KAAK,KAAK,UAAU;AAChE,qBAAa,QAAQ,QAAQ,SAAS,KAAK,KAAK,IAAI;AAEpD,uBAAe,QAAQ,SAAS,SAAS,KAAK,KAAK,KAAK;AACxD,uBAAe,QAAQ,YAAY,SAAS,KAAK,KAAK,QAAQ;AAC9D,uBAAe,QAAQ,SAAS,KAAK;AACrC,uBAAe,QAAQ,cAAc,SAAS,KAAK,KAAK,UAAU;AAClE,uBAAe,QAAQ,QAAQ,SAAS,KAAK,KAAK,IAAI;AAEtD,aAAK,UAAU;AACf,YAAI,KAAK,aAAa,QAAQ,KAAK,YAAY,MAAM;AACnD,eAAK,QAAQ,KAAK,EAAE,MAAM,IAAI,KAAK,WAAW,IAAS,KAAK,SAAS,IAAa,KAAK,QAAQ,aAAkB;AAAA,QACnH,OACK;AACH,UAAA,SAAS,OAAA;AAAA,QACX;AACA,gBAAQ,IAAI,qBAAqB,QAAQ;AAAA,MAC3C,SAAS,OAAO;AACd,aAAK,UAAU;AACf,aAAK,eAAe;AACpB,gBAAQ,IAAI,iBAAiB,KAAK;AAClC,mBAAW,MAAM;AACf,eAAK,eAAe;AAAA,QACtB,GAAG,GAAI;AAAA,MACT;AAAA,IACF;AAAA,IACA,MAAM,eAAe;AACnB,UAAI;AACF,aAAK,UAAU;AACf,cAAM,qBAAqB,KAAK,aAAa,UAAU,KAAK,EAAE,QAAQ,oBAAoB,EAAE;AAC5F,cAAM,WAAW,mBAAmB,QAAQ,iBAAiB,EAAE;AAE/D,cAAM,WAAW,MAAM,KAAK,OAAO,KAAK,kBAAkB;AAAA,UACxD,OAAO,KAAK;AAAA,UACZ,MAAM,KAAK;AAAA,UACX;AAAA,UACA,UAAU,KAAK;AAAA,UACf,YAAY;AAAA,QAAA,CACb;AAED,YAAI,SAAS,KAAK,eAAe,KAAK;AAClC,eAAK,UAAU;AACf,eAAK,eAAe,SAAS,KAAK;AAClC,kBAAQ,IAAI,oBAAoB,SAAS,IAAI;AAAA,QACjD;AACA,YAAI,SAAS,KAAK,eAAe,KAAK;AACpC,gBAAM,WAAW,SAAS,KAAK;AAC/B,eAAK,iBAAiB,+CAA+C,WAAW,SAAS,KAAK;AAC9F,eAAK,UAAU;AACf,kBAAQ,IAAI,4BAA4B,QAAQ;AAAA,QAClD;AACA,mBAAW,MAAM;AACb,eAAK,iBAAiB;AACtB,eAAK,eAAe;AACpB,UAAA,SAAS,OAAA;AAAA,QACX,GAAG,GAAK;AAAA,MAEZ,SAAS,OAAO;AACd,aAAK,UAAU;AACf,aAAK,eAAe;AACpB,mBAAW,MAAM;AACf,eAAK,eAAe;AAAA,QACtB,GAAG,GAAI;AACP,gBAAQ,IAAI,wBAAwB,KAAK;AAAA,MAC3C;AAAA,IACF;AAAA,EAAA;AAAA,EAEF,UAAU;AACR,QAAI,OAAO,mBAAmB,eAAe,eAAe,QAAQ,OAAO,GAAG;AAC5E,YAAM,WAAW,eAAe,QAAQ,UAAU;AAClD,WAAK,QAAQ,KAAK,IAAI,QAAQ,EAAE;AAAA,IAClC;AAEA,UAAM,YAAY,KAAK,OAAO,MAAM;AACpC,UAAM,aAAa,KAAK,OAAO,MAAM;AACrC,UAAM,eAAe,KAAK,OAAO,MAAM;AAEvC,SAAK,YAAY;AACjB,SAAK,cAAc;AACnB,SAAK,WAAW;AAAA,EAClB;AACF;;;;;;;;;;;;","names":[],"sources":["../../../../pages/u/index.vue"],"sourcesContent":["<template>\n  <client-only>\n    <div class=\"w-full min-h-screen flex items-center justify-center bg-gray-50 py-8\">\n      <div class=\"w-full max-w-md mx-4\">\n        <!-- Carte de connexion -->\n        <div class=\"bg-white rounded-lg shadow-sm overflow-hidden border border-gray-200\">\n          <!-- En-tête sobre -->\n          <div class=\"bg-white p-6 text-center border-b border-gray-200\">\n            <div class=\"flex justify-center mb-4\">\n              <div class=\"w-16 h-16 rounded-full bg-gray-100 flex items-center justify-center border border-gray-300\">\n                <span class=\"text-2xl font-bold text-gray-700\">B</span>\n              </div>\n            </div>\n            <h1 class=\"text-2xl font-semibold text-gray-800\">Beat Expertise</h1>\n            <p class=\"text-gray-600 mt-2\">Plateforme de connexion</p>\n          </div>\n          \n          <!-- Contenu du formulaire -->\n          <div class=\"p-8\">\n            <!-- Messages d'alerte -->\n            <div v-if=\"loading\" class=\"flex justify-center my-4\">\n              <div class=\"loader\"></div>\n            </div>\n            \n            <div v-if=\"successMessage && !loading\" class=\"bg-green-50 border border-green-200 text-green-700 p-4 rounded mb-6\">\n              <p v-html=\"successMessage\"></p>\n            </div>\n            \n            <div v-if=\"errorMessage && !loading\" class=\"bg-red-50 border border-red-200 text-red-700 p-4 rounded mb-6\">\n              <p v-html=\"errorMessage\"></p>\n            </div>\n            \n            <!-- Formulaire de connexion -->\n            <div v-if=\"showLogin && !loading\">\n              <h2 class=\"text-xl font-semibold text-gray-800 mb-2 text-center\">Connexion</h2>\n              <p class=\"text-gray-600 text-center mb-8\">Accédez à votre espace personnel</p>\n              \n              <form @submit.prevent=\"postLogin()\" class=\"space-y-6\">\n                <div>\n                  <label for=\"loginLogin\" class=\"block text-sm font-medium text-gray-700 mb-2\">Adresse email</label>\n                  <div class=\"relative\">\n                    <div class=\"absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none\">\n                      <svg class=\"h-5 w-5 text-gray-400\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" xmlns=\"http://www.w3.org/2000/svg\">\n                        <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M16 12a4 4 0 10-8 0 4 4 0 008 0zm0 0v1.5a2.5 2.5 0 005 0V12a9 9 0 10-9 9m4.5-1.206a8.959 8.959 0 01-4.5 1.207\"></path>\n                      </svg>\n                    </div>\n                    <input \n                      type=\"text\" \n                      id=\"loginLogin\" \n                      v-model=\"loginLogin\" \n                      placeholder=\"Votre adresse email\" \n                      class=\"w-full pl-10 pr-4 py-3 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500 transition-colors duration-200\"\n                    />\n                  </div>\n                </div>\n\n                <div>\n                  <label for=\"loginPassword\" class=\"block text-sm font-medium text-gray-700 mb-2\">Mot de passe</label>\n                  <div class=\"relative\">\n                    <div class=\"absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none\">\n                      <svg class=\"h-5 w-5 text-gray-400\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" xmlns=\"http://www.w3.org/2000/svg\">\n                        <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z\"></path>\n                      </svg>\n                    </div>\n                    <input \n                      type=\"password\" \n                      id=\"loginPassword\" \n                      v-model=\"loginPassword\" \n                      placeholder=\"Votre mot de passe\" \n                      class=\"w-full pl-10 pr-4 py-3 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500 transition-colors duration-200\"\n                    />\n                  </div>\n                </div>\n                \n                <div class=\"flex items-center justify-between\">\n                  <div class=\"flex items-center\">\n                    <input \n                      type=\"checkbox\" \n                      id=\"acceptance\" \n                      class=\"h-4 w-4 text-blue-500 focus:ring-blue-400 border-gray-300 rounded\"\n                      checked\n                    />\n                    <label for=\"acceptance\" class=\"ml-2 block text-sm text-gray-700\">Conserver ma session</label>\n                  </div>\n                  \n                  <a href=\"#\" class=\"text-sm text-blue-500 hover:text-blue-700 transition-colors duration-200\">\n                    Mot de passe oublié?\n                  </a>\n                </div>\n\n                <button\n                  type=\"submit\"\n                  class=\"w-full py-3 px-4 bg-gray-800 text-white font-medium rounded-md hover:bg-gray-900 transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-800\"\n                >\n                  Se connecter\n                </button>\n              </form>\n              \n              <div class=\"mt-6 text-center\">\n                <p class=\"text-gray-600\">\n                  Pas de compte? \n                  <a \n                    href=\"mailto:info@primetek.africa\" \n                    class=\"font-medium text-blue-500 hover:text-blue-700 transition-colors duration-200\"\n                  >\n                    Faites une requête\n                  </a>\n                </p>\n              </div>\n            </div>\n\n            <!-- Formulaire d'inscription -->\n            <div v-else class=\"space-y-6\">\n              <h2 class=\"text-xl font-semibold text-gray-800 mb-2 text-center\">Créer un compte</h2>\n              <p class=\"text-gray-600 text-center mb-8\">Rejoignez notre plateforme</p>\n              \n              <form @submit.prevent=\"validateRegisterForm() && postRegister()\">\n                <div class=\"mb-4\">\n                  <label for=\"registerName\" class=\"block text-sm font-medium text-gray-700 mb-2\">Votre nom complet</label>\n                  <div class=\"relative\">\n                    <div class=\"absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none\">\n                      <svg class=\"h-5 w-5 text-gray-400\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" xmlns=\"http://www.w3.org/2000/svg\">\n                        <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z\"></path>\n                      </svg>\n                    </div>\n                    <input \n                      type=\"text\" \n                      id=\"registerName\" \n                      v-model=\"registerName\" \n                      placeholder=\"Votre nom complet\" \n                      class=\"w-full pl-10 pr-4 py-3 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500 transition-colors duration-200\"\n                    />\n                  </div>\n                </div>\n                \n                <div v-if=\"registerName != ''\" class=\"mb-4 bg-gray-50 p-3 rounded-md\">\n                  <p class=\"text-sm text-gray-700\">\n                    Votre identifiant sera: \n                    <span class=\"font-medium text-gray-800\">{{ generatedUsername }}</span>\n                  </p>\n                </div>\n                \n                <div class=\"mb-4\">\n                  <label for=\"registerEmail\" class=\"block text-sm font-medium text-gray-700 mb-2\">Adresse email</label>\n                  <div class=\"relative\">\n                    <div class=\"absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none\">\n                      <svg class=\"h-5 w-5 text-gray-400\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" xmlns=\"http://www.w3.org/2000/svg\">\n                        <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z\"></path>\n                      </svg>\n                    </div>\n                    <input \n                      type=\"email\" \n                      id=\"registerEmail\" \n                      v-model=\"registerEmail\" \n                      placeholder=\"Votre adresse email\" \n                      class=\"w-full pl-10 pr-4 py-3 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500 transition-colors duration-200\"\n                    />\n                  </div>\n                </div>\n                \n                <div class=\"mb-6\">\n                  <label for=\"registerPassword\" class=\"block text-sm font-medium text-gray-700 mb-2\">Mot de passe</label>\n                  <div class=\"relative\">\n                    <div class=\"absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none\">\n                      <svg class=\"h-5 w-5 text-gray-400\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" xmlns=\"http://www.w3.org/2000/svg\">\n                        <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z\"></path>\n                      </svg>\n                    </div>\n                    <input \n                      type=\"password\" \n                      id=\"registerPassword\" \n                      v-model=\"registerPassword\" \n                      placeholder=\"Créez un mot de passe sécurisé\" \n                      class=\"w-full pl-10 pr-4 py-3 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500 transition-colors duration-200\"\n                    />\n                  </div>\n                  <p class=\"text-xs text-gray-500 mt-1\">Minimum 8 caractères</p>\n                </div>\n                \n                <div v-if=\"formReady && !validateRegisterForm()\" class=\"mb-4 bg-red-50 p-3 rounded-md border border-red-200\">\n                  <p class=\"text-sm text-red-700\">Veuillez remplir tous les champs avec des informations valides</p>\n                </div>\n                \n                <button\n                  type=\"submit\"\n                  class=\"w-full py-3 px-4 bg-gray-800 text-white font-medium rounded-md hover:bg-gray-900 transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-800\"\n                >\n                  Créer un compte\n                </button>\n              </form>\n              \n              <div class=\"mt-6 text-center\">\n                <p class=\"text-gray-600\">\n                  Vous avez déjà un compte? \n                  <a \n                    @click=\"toggleForm('login')\" \n                    class=\"font-medium text-blue-500 hover:text-blue-700 transition-colors duration-200 cursor-pointer\"\n                  >\n                    Connectez-vous\n                  </a>\n                </p>\n              </div>\n            </div>\n          </div>\n        </div>\n        \n        <div class=\"mt-8 text-center\">\n          <p class=\"text-sm text-gray-500\">© 2023 Beat Expertise. Tous droits réservés.</p>\n        </div>\n      </div>\n    </div>\n  </client-only>\n</template>\n\n<script>\nimport aosMixin from '@/mixins/aos';\n\nexport default {\n  name: 'user-component',\n  layout: 'user',\n  mixins: [aosMixin],\n  data() {\n    return {\n      showLogin: true,\n      userRegistred: false,\n      loginLogin: '',\n      loginPassword: '',\n      registerName: '',\n      registerEmail: '',\n      registerPassword: '',\n      formReady: false,\n      nextroute: null,\n      nextpost: null,\n      nextCreator: null,\n      successMessage: '', \n      errorMessage: '',\n      loading: false\n    };\n  },\n  computed: {\n    generatedUsername() {\n      const normalizedName = this.registerName.toLowerCase().normalize(\"NFD\").replace(/[\\u0300-\\u036f]/g, \"\");\n      const username = normalizedName.replace(/\\s/g, \"\");\n      return username;\n    },\n  },\n  methods: {\n    login() {\n      console.log('Logging in with:', this.loginLogin, this.loginPassword);\n    },\n    register() {\n      console.log('Registering with:', this.registerName, this.registerEmail, this.registerPassword);\n    },\n    toggleForm(formType) {\n      this.showLogin = formType === 'login';\n    },\n    validateRegisterForm() {\n      this.formReady = true;\n      if (this.registerName === '' || this.registerEmail === '' || this.registerPassword === '' || this.registerPassword.length < 8) {\n        return false;\n      }\n      return true;\n    },\n    async postLogin() {\n      try {\n        this.loading = true;\n        const response = await this.$axios.post('/user/login', {\n          login: this.loginLogin,\n          password: this.loginPassword,\n        });\n\n        console.log(response.data);\n        const userData = response.data.user;\n        const token = response.data.token;\n        \n        localStorage.setItem('email', response.data.user.email);\n        localStorage.setItem('username', response.data.user.username);\n        localStorage.setItem('token', token);\n        localStorage.setItem('accesshash', response.data.user.accesshash);\n        localStorage.setItem('name', response.data.user.name);\n\n        sessionStorage.setItem('email', response.data.user.email);\n        sessionStorage.setItem('username', response.data.user.username);\n        sessionStorage.setItem('token', token);\n        sessionStorage.setItem('accesshash', response.data.user.accesshash);\n        sessionStorage.setItem('name', response.data.user.name);\n        \n        this.loading = false;\n        if (this.nextroute != null && this.nextpost != null) {\n          this.$router.push({ path: `/${this.nextCreator}` + `/${this.nextroute}` + \"/\" +`${this.nextpost}` + '#comments' });\n        }\n        else {\n          location.reload();\n        }\n        console.log('Login successful!', userData);\n      } catch (error) {\n        this.loading = false;\n        this.errorMessage = 'Échec de la connexion! Veuillez vérifier vos identifiants.';\n        console.log('Login failed:', error);\n        setTimeout(() => {\n          this.errorMessage = '';\n        }, 4000);\n      }\n    },\n    async postRegister() {\n      try { \n        this.loading = true;\n        const normalizedUsername = this.registerName.normalize(\"NFD\").replace(/[\\u0300-\\u036f]/g, \"\");\n        const username = normalizedUsername.replace(/[^a-zA-Z0-9]/g, \"\");\n\n        const response = await this.$axios.post('/user/register', {\n          email: this.registerEmail,\n          name: this.registerName,\n          username: username,\n          password: this.registerPassword,\n          accesshash: 'beat_user'\n        });\n        \n        if (response.data.status_code == 409) {\n            this.loading = false; \n            this.errorMessage = response.data.status_message;\n            console.log('Account exists !', response.data);\n        } \n        if (response.data.status_code == 200) {\n          const userData = response.data.user;\n          this.successMessage = 'Inscription réussie! Connectez-vous avec: ' + username + ' ou ' + this.registerEmail;\n          this.loading = false; \n          console.log('Registration successful!', userData);\n        }\n        setTimeout(() => {\n            this.successMessage = '';\n            this.errorMessage = ''\n            location.reload();\n          }, 10000);\n        \n      } catch (error) {\n        this.loading = false;\n        this.errorMessage = 'Échec de l\\'inscription! Veuillez réessayer.';\n        setTimeout(() => {\n          this.errorMessage = '';\n        }, 6000);\n        console.log('Registration failed:', error);\n      }\n    },\n  },\n  mounted() {\n    if (typeof sessionStorage !== 'undefined' && sessionStorage.getItem('token')) { \n      const username = sessionStorage.getItem('username');\n      this.$router.push(`/${username}`);\n    }\n    \n    const nextParam = this.$route.query.next;\n    const routeParam = this.$route.query.route;\n    const creatorParam = this.$route.query.creator;\n\n    this.nextroute = nextParam;\n    this.nextCreator = creatorParam;\n    this.nextpost = routeParam;\n  },\n};\n</script>\n\n<style scoped>\n.loader {\n  border: 3px solid #f3f3f3;\n  border-top: 3px solid #4B5563;\n  border-radius: 50%;\n  width: 30px;\n  height: 30px;\n  animation: spin 1s linear infinite;\n}\n\n@keyframes spin {\n  0% { transform: rotate(0deg); }\n  100% { transform: rotate(360deg); }\n}\n</style>"],"version":3}